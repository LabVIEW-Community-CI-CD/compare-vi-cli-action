{
  "schema": "promotion-contract/v1",
  "schemaVersion": "1.0.0",
  "check_context": "Promotion Contract / promotion-contract",
  "require_check_context_in_branch_protection": false,
  "channels": {
    "rc": {
      "version_pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$",
      "requires_approval_gate": true,
      "allows_latest_tag": false,
      "required_evidence": [
        "contract-alignment",
        "promotion-evidence-ledger",
        "certification-matrix",
        "supply-chain-trust-gate",
        "rollback-drill-health",
        "shared-source-resolution"
      ]
    },
    "stable": {
      "version_pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "requires_approval_gate": true,
      "allows_latest_tag": true,
      "required_evidence": [
        "contract-alignment",
        "promotion-evidence-ledger",
        "certification-matrix",
        "supply-chain-trust-gate",
        "rollback-drill-health",
        "shared-source-resolution"
      ]
    },
    "lts": {
      "version_pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "requires_approval_gate": true,
      "allows_latest_tag": true,
      "required_evidence": [
        "contract-alignment",
        "promotion-evidence-ledger",
        "certification-matrix",
        "supply-chain-trust-gate",
        "rollback-drill-health",
        "shared-source-resolution"
      ]
    }
  },
  "required_status_checks": {
    "develop": [
      "lint",
      "fixtures",
      "session-index",
      "issue-snapshot",
      "semver",
      "Policy Guard (Upstream) / policy-guard",
      "hook-parity (ubuntu-latest)",
      "vi-history-scenarios-linux",
      "agent-review-policy",
      "commit-integrity"
    ],
    "release/*": [
      "lint",
      "pester",
      "publish",
      "vi-binary-check",
      "vi-compare",
      "mock-cli",
      "Policy Guard (Upstream) / policy-guard"
    ]
  },
  "artifacts": {
    "ledger_schema": "docs/schemas/promotion-evidence-ledger-v1.schema.json",
    "default_output_dir": "tests/results/promotion-contract"
  }
}
