{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.labview-community-cicd.example/compare-vi-cli-action/operator-cost-profile-v1.schema.json",
  "title": "Operator Cost Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "currency",
    "defaultOperatorId",
    "operators"
  ],
  "properties": {
    "schema": {
      "const": "priority/operator-cost-profile@v1"
    },
    "currency": {
      "const": "USD"
    },
    "defaultOperatorId": {
      "type": "string",
      "minLength": 1
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operator"
      }
    }
  },
  "$defs": {
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "laborRateUsdPerHour",
        "pricingBasis",
        "appliesToAgentRuntime",
        "active"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "laborRateUsdPerHour": {
          "type": "number",
          "minimum": 0
        },
        "pricingBasis": {
          "type": "string",
          "enum": [
            "agent-runtime-hour"
          ]
        },
        "appliesToAgentRuntime": {
          "type": "boolean"
        },
        "active": {
          "type": "boolean"
        }
      }
    }
  }
}
