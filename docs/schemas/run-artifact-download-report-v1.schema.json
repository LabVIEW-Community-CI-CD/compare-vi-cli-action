{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/run-artifact-download-report-v1.schema.json",
  "title": "priority/run-artifact-download@v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "generatedAt",
    "status",
    "repository",
    "runId",
    "destinationRoot",
    "destinationRootPolicy",
    "requestedArtifacts",
    "discovery",
    "downloads",
    "summary",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "priority/run-artifact-download@v1"
    },
    "schemaVersion": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "repository": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "destinationRoot": {
      "type": "string"
    },
    "destinationRootPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "source", "baseRoot", "relativeRoot", "usesExternalRoot"],
      "properties": {
        "strategy": {
          "enum": ["explicit", "environment", "policy-preferred-root", "repo-default"]
        },
        "source": {
          "type": "string"
        },
        "baseRoot": {
          "type": "string"
        },
        "relativeRoot": {
          "type": ["string", "null"]
        },
        "usesExternalRoot": {
          "type": "boolean"
        }
      }
    },
    "requestedArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "failureClass",
        "command",
        "errorMessage",
        "availableArtifacts"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "failureClass": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "errorMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "availableArtifacts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/artifact"
          }
        }
      }
    },
    "downloads": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/download"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availableArtifactCount",
        "requestedArtifactCount",
        "downloadedCount",
        "missingCount",
        "failedCount"
      ],
      "properties": {
        "availableArtifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "requestedArtifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "downloadedCount": {
          "type": "integer",
          "minimum": 0
        },
        "missingCount": {
          "type": "integer",
          "minimum": 0
        },
        "failedCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "sizeInBytes",
        "expired",
        "createdAt",
        "updatedAt",
        "workflowRun"
      ],
      "properties": {
        "id": {
          "type": [
            "integer",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "sizeInBytes": {
          "type": [
            "integer",
            "null"
          ]
        },
        "expired": {
          "type": "boolean"
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "workflowRun": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "id",
            "headBranch",
            "headSha"
          ],
          "properties": {
            "id": {
              "type": [
                "integer",
                "null"
              ]
            },
            "headBranch": {
              "type": [
                "string",
                "null"
              ]
            },
            "headSha": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "download": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "failureClass",
        "command",
        "destination",
        "artifact",
        "files",
        "stdout",
        "stderr",
        "errorMessage"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "downloaded",
            "missing",
            "failed"
          ]
        },
        "failureClass": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "artifact": {
          "oneOf": [
            {
              "$ref": "#/definitions/artifact"
            },
            {
              "type": "null"
            }
          ]
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stdout": {
          "type": [
            "string",
            "null"
          ]
        },
        "stderr": {
          "type": [
            "string",
            "null"
          ]
        },
        "errorMessage": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
