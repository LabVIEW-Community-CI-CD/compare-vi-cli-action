{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/monitoring-work-injection-report-v1.schema.json",
  "title": "Monitoring Work Injection Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generatedAt",
    "repository",
    "policy",
    "inputs",
    "evidence",
    "selectedRule",
    "summary",
    "helperCallsExecuted"
  ],
  "properties": {
    "schema": {
      "const": "priority/monitoring-work-injection-report@v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "requireQueueEmpty",
        "ruleIds"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "requireQueueEmpty": {
          "type": "boolean"
        },
        "ruleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queueEmptyReportPath",
        "monitoringModePath",
        "hostSignalPath",
        "wakeAdjudicationPath",
        "wakeWorkSynthesisPath",
        "wakeInvestmentAccountingPath"
      ],
      "properties": {
        "queueEmptyReportPath": {
          "type": "string",
          "minLength": 1
        },
        "monitoringModePath": {
          "type": "string",
          "minLength": 1
        },
        "hostSignalPath": {
          "type": "string",
          "minLength": 1
        },
        "wakeAdjudicationPath": {
          "type": "string",
          "minLength": 1
        },
        "wakeWorkSynthesisPath": {
          "type": "string",
          "minLength": 1
        },
        "wakeInvestmentAccountingPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queueEmpty",
        "monitoringMode",
        "hostSignal",
        "wake"
      ],
      "properties": {
        "queueEmpty": {
          "anyOf": [
            {
              "$ref": "#/$defs/queueEmpty"
            },
            {
              "type": "null"
            }
          ]
        },
        "monitoringMode": {
          "anyOf": [
            {
              "$ref": "#/$defs/monitoringMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "hostSignal": {
          "anyOf": [
            {
              "$ref": "#/$defs/hostSignal"
            },
            {
              "type": "null"
            }
          ]
        },
        "wake": {
          "anyOf": [
            {
              "$ref": "#/$defs/wakeEvidence"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "selectedRule": {
      "anyOf": [
        {
          "$ref": "#/$defs/selectedRule"
        },
        {
          "type": "null"
        }
      ]
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "helperCallsExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "queueEmpty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "reason",
        "openIssueCount"
      ],
      "properties": {
        "schema": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "openIssueCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "monitoringMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "futureAgentAction",
        "wakeConditionCount"
      ],
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "futureAgentAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "wakeConditionCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "hostSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "provider",
        "daemonFingerprint"
      ],
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "daemonFingerprint": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "wakeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "decision",
        "status",
        "nextAction",
        "recommendedOwnerRepository",
        "suppressIssueInjection",
        "suppressTemplateIssueInjection",
        "suppressDownstreamIssueInjection",
        "accountingBucket",
        "accountingStatus",
        "paybackStatus"
      ],
      "properties": {
        "classification": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "nextAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendedOwnerRepository": {
          "type": [
            "string",
            "null"
          ]
        },
        "suppressIssueInjection": {
          "type": "boolean"
        },
        "suppressTemplateIssueInjection": {
          "type": "boolean"
        },
        "suppressDownstreamIssueInjection": {
          "type": "boolean"
        },
        "accountingBucket": {
          "type": [
            "string",
            "null"
          ]
        },
        "accountingStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "paybackStatus": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "selectedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requireMonitoringMode",
        "issueTitle",
        "dedupeMarker",
        "resolvedDedupeMarker",
        "labels",
        "conditions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "requireMonitoringMode": {
          "type": [
            "string",
            "null"
          ]
        },
        "issueTitle": {
          "type": "string",
          "minLength": 1
        },
        "dedupeMarker": {
          "type": "string",
          "minLength": 1
        },
        "resolvedDedupeMarker": {
          "type": [
            "string",
            "null"
          ]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "conditions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hostSignalStatus",
            "wakeClassification",
            "wakeDecision",
            "wakeStatus",
            "recommendedOwnerRepository",
            "wakeAccountingBucket",
            "wakeAccountingStatus"
          ],
          "properties": {
            "hostSignalStatus": {
              "type": [
                "string",
                "null"
              ]
            },
            "wakeClassification": {
              "type": [
                "string",
                "null"
              ]
            },
            "wakeDecision": {
              "type": [
                "string",
                "null"
              ]
            },
            "wakeStatus": {
              "type": [
                "string",
                "null"
              ]
            },
            "recommendedOwnerRepository": {
              "type": [
                "string",
                "null"
              ]
            },
            "wakeAccountingBucket": {
              "type": [
                "string",
                "null"
              ]
            },
            "wakeAccountingStatus": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "injected",
        "reason",
        "issueNumber",
        "issueUrl",
        "triggerId"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "no-trigger",
            "existing-issue",
            "would-create-issue",
            "created-issue",
            "suppressed-wake",
            "monitoring-only",
            "external-route",
            "policy-blocked"
          ]
        },
        "injected": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "issueNumber": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "issueUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "triggerId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
