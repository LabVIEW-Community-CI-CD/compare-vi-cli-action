{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/monitoring-work-injection-policy-v1.schema.json",
  "title": "Monitoring Work Injection Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "compareRepository",
    "requireQueueEmpty",
    "rules"
  ],
  "properties": {
    "schema": {
      "const": "priority/monitoring-work-injection-policy@v1"
    },
    "compareRepository": {
      "type": "string",
      "minLength": 1
    },
    "requireQueueEmpty": {
      "type": "boolean"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "issue"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "requireMonitoringMode": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hostSignalStatus": {
              "type": "string",
              "minLength": 1
            },
            "wakeClassification": {
              "type": "string",
              "enum": [
                "live-defect",
                "stale-artifact",
                "branch-target-drift",
                "platform-permission-gap",
                "environment-only"
              ]
            },
            "wakeDecision": {
              "type": "string",
              "enum": [
                "suppress",
                "monitor",
                "compare-governance-work",
                "template-work",
                "consumer-proving-drift",
                "investment-work"
              ]
            },
            "wakeStatus": {
              "type": "string",
              "enum": [
                "suppressed",
                "monitoring",
                "actionable"
              ]
            },
            "recommendedOwnerRepository": {
              "type": "string",
              "minLength": 1
            },
            "wakeAccountingBucket": {
              "type": "string",
              "enum": [
                "suppressed-wake",
                "monitoring-wake",
                "compare-governance-work",
                "template-work",
                "consumer-proving-drift",
                "investment-work"
              ]
            },
            "wakeAccountingStatus": {
              "type": "string",
              "enum": [
                "pass",
                "warn",
                "fail"
              ]
            }
          }
        },
        "issue": {
          "$ref": "#/$defs/issueDefinition"
        }
      }
    },
    "issueDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "dedupeMarker",
        "labels",
        "bodyLines"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "dedupeMarker": {
          "type": "string",
          "minLength": 1
        },
        "dedupeDimension": {
          "type": "string",
          "enum": [
            "classification",
            "decision",
            "next-action",
            "recommended-owner-repository",
            "accounting-bucket"
          ]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "bodyLines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
