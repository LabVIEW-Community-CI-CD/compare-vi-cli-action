{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.labview-community-cicd.example/compare-vi-cli-action/agent-spend-gap-slo-v1.schema.json",
  "title": "Agent Spend Gap SLO Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "generatedAt", "repository", "inputs", "window", "summary", "fundedThroughput", "gaps"],
  "properties": {
    "schema": { "const": "priority/agent-spend-gap-slo@v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repository": { "$ref": "#/$defs/nullableString" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["costRollupPath", "throughputScorecardPath", "gapThresholdMinutes"],
      "properties": {
        "costRollupPath": { "$ref": "#/$defs/inputRef" },
        "throughputScorecardPath": { "$ref": "#/$defs/inputRef" },
        "gapThresholdMinutes": { "type": "number", "minimum": 0 }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firstSpendAt", "lastSpendAt", "observedMinutes"],
      "properties": {
        "firstSpendAt": { "$ref": "#/$defs/nullableString" },
        "lastSpendAt": { "$ref": "#/$defs/nullableString" },
        "observedMinutes": { "type": "number", "minimum": 0 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons", "metrics"],
      "properties": {
        "status": { "enum": ["pass", "warn"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "totalSpendTurns",
            "totalGapCount",
            "operatorSteeringGapCount",
            "optimizationSignalGapCount",
            "trackedGapCount",
            "quietWindowGapCount",
            "unexplainedGapCount",
            "largestGapMinutes",
            "totalGapMinutes"
          ],
          "properties": {
            "totalSpendTurns": { "type": "integer", "minimum": 0 },
            "totalGapCount": { "type": "integer", "minimum": 0 },
            "operatorSteeringGapCount": { "type": "integer", "minimum": 0 },
            "optimizationSignalGapCount": { "type": "integer", "minimum": 0 },
            "trackedGapCount": { "type": "integer", "minimum": 0 },
            "quietWindowGapCount": { "type": "integer", "minimum": 0 },
            "unexplainedGapCount": { "type": "integer", "minimum": 0 },
            "largestGapMinutes": { "type": "number", "minimum": 0 },
            "totalGapMinutes": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "fundedThroughput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fundingWindow", "throughputWindow", "metrics", "provenance"],
      "properties": {
        "fundingWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "invoiceTurnId",
            "mode",
            "calibrationWindowId",
            "activationState",
            "fundingPurpose",
            "kind",
            "prepaidUsd",
            "actualUsdConsumed",
            "heuristicUsdDelta",
            "heuristicUsdDeltaRatio"
          ],
          "properties": {
            "invoiceTurnId": { "$ref": "#/$defs/nullableString" },
            "mode": { "$ref": "#/$defs/nullableString" },
            "calibrationWindowId": { "$ref": "#/$defs/nullableString" },
            "activationState": { "$ref": "#/$defs/nullableString" },
            "fundingPurpose": { "$ref": "#/$defs/nullableString" },
            "kind": { "type": "string", "enum": ["operational", "calibration"] },
            "prepaidUsd": { "type": ["number", "null"], "minimum": 0 },
            "actualUsdConsumed": { "type": ["number", "null"], "minimum": 0 },
            "heuristicUsdDelta": { "type": ["number", "null"] },
            "heuristicUsdDeltaRatio": { "type": ["number", "null"] }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "validatedPullRequestCount",
            "closedIssueCount",
            "promotionEvidenceCount",
            "laneMinutesAllocated",
            "hostedWaitEscapeCount",
            "operatorSteeringEventCount",
            "validatedPullRequestsPerFundedDollar",
            "closedIssuesPerFundedDollar",
            "promotionEvidencePerFundedDollar",
            "laneMinutesAllocatedPerFundedDollar",
            "hostedWaitEscapesPerFundedDollar",
            "operatorSteeringEventsPerFundedDollar"
          ],
          "properties": {
            "validatedPullRequestCount": { "type": "integer", "minimum": 0 },
            "closedIssueCount": { "type": "integer", "minimum": 0 },
            "promotionEvidenceCount": { "type": "integer", "minimum": 0 },
            "laneMinutesAllocated": { "type": "number", "minimum": 0 },
            "hostedWaitEscapeCount": { "type": "integer", "minimum": 0 },
            "operatorSteeringEventCount": { "type": "integer", "minimum": 0 },
            "validatedPullRequestsPerFundedDollar": { "type": ["number", "null"], "minimum": 0 },
            "closedIssuesPerFundedDollar": { "type": ["number", "null"], "minimum": 0 },
            "promotionEvidencePerFundedDollar": { "type": ["number", "null"], "minimum": 0 },
            "laneMinutesAllocatedPerFundedDollar": { "type": ["number", "null"], "minimum": 0 },
            "hostedWaitEscapesPerFundedDollar": { "type": ["number", "null"], "minimum": 0 },
            "operatorSteeringEventsPerFundedDollar": { "type": ["number", "null"], "minimum": 0 }
          }
        },
        "throughputWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currentCycleIdleStatus",
            "currentCycleIdleSource",
            "currentCycleIdleObservedAt",
            "currentCycleIdleNextWakeCondition"
          ],
          "properties": {
            "currentCycleIdleStatus": { "enum": ["observed", "missing"] },
            "currentCycleIdleSource": { "$ref": "#/$defs/nullableString" },
            "currentCycleIdleObservedAt": { "$ref": "#/$defs/nullableDateTime" },
            "currentCycleIdleNextWakeCondition": { "$ref": "#/$defs/nullableString" }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["costRollup", "throughputScorecard", "sourceKind", "sourcePathEvidence", "operatorNote"],
          "properties": {
            "costRollup": { "$ref": "#/$defs/inputRef" },
            "throughputScorecard": { "$ref": "#/$defs/inputRef" },
            "sourceKind": { "type": "string", "minLength": 1 },
            "sourcePathEvidence": { "type": "string", "minLength": 1 },
            "operatorNote": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    }
  },
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "nullableDateTime": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "inputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "error"],
      "properties": {
        "path": { "$ref": "#/$defs/nullableString" },
        "exists": { "type": "boolean" },
        "error": { "$ref": "#/$defs/nullableString" }
      }
    },
    "turnEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issueNumber",
        "turnId",
        "laneId",
        "agentRole",
        "providerId",
        "effectiveModel",
        "effectiveReasoningEffort",
        "amountUsd",
        "exactness"
      ],
      "properties": {
        "issueNumber": { "type": ["integer", "null"], "minimum": 0 },
        "turnId": { "$ref": "#/$defs/nullableString" },
        "laneId": { "$ref": "#/$defs/nullableString" },
        "agentRole": { "$ref": "#/$defs/nullableString" },
        "providerId": { "$ref": "#/$defs/nullableString" },
        "effectiveModel": { "$ref": "#/$defs/nullableString" },
        "effectiveReasoningEffort": { "$ref": "#/$defs/nullableString" },
        "amountUsd": { "type": "number", "minimum": 0 },
        "exactness": { "type": "string", "enum": ["exact", "estimated"] }
      }
    },
    "gapEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readyPrInventory",
        "currentWorkerUtilizationRatio",
        "concurrentLaneActiveCount",
        "concurrentLaneDeferredCount",
        "hostedWaitEscapeCount",
        "currentCycleIdleStatus",
        "currentCycleIdleSource",
        "currentCycleIdleObservedAt",
        "currentCycleIdleNextWakeCondition",
        "throughputReasons",
        "operatorSteeringEventCount",
        "operatorSteeringKinds",
        "operatorSteeringTriggerKinds",
        "operatorSteeringInvoiceTurnIds"
      ],
      "properties": {
        "readyPrInventory": { "type": ["integer", "null"], "minimum": 0 },
        "currentWorkerUtilizationRatio": { "type": ["number", "null"], "minimum": 0 },
        "concurrentLaneActiveCount": { "type": ["integer", "null"], "minimum": 0 },
        "concurrentLaneDeferredCount": { "type": ["integer", "null"], "minimum": 0 },
        "hostedWaitEscapeCount": { "type": ["integer", "null"], "minimum": 0 },
        "currentCycleIdleStatus": { "enum": ["observed", "missing"] },
        "currentCycleIdleSource": { "$ref": "#/$defs/nullableString" },
        "currentCycleIdleObservedAt": { "$ref": "#/$defs/nullableDateTime" },
        "currentCycleIdleNextWakeCondition": { "$ref": "#/$defs/nullableString" },
        "throughputReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "operatorSteeringEventCount": { "type": "integer", "minimum": 0 },
        "operatorSteeringKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "operatorSteeringTriggerKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "operatorSteeringInvoiceTurnIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startedAt",
        "endedAt",
        "durationMinutes",
        "previousTurn",
        "nextTurn",
        "classification",
        "trackingIssueNumber",
        "evidence"
      ],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number", "minimum": 0 },
        "previousTurn": { "$ref": "#/$defs/turnEvidence" },
        "nextTurn": { "$ref": "#/$defs/turnEvidence" },
        "classification": {
          "enum": ["operator-steering", "optimization-signal", "tracked-followup", "accepted-quiet-window", "insufficient-evidence"]
        },
        "trackingIssueNumber": { "type": ["integer", "null"], "minimum": 0 },
        "evidence": { "$ref": "#/$defs/gapEvidence" }
      }
    }
  }
}
