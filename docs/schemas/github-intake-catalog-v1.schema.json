{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comparevi.dev/schemas/github-intake-catalog-v1.schema.json",
  "title": "GitHub Intake Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "gh-issue-create",
            "priority-pr-create",
            "gh-pr-create",
            "branch-orchestrator",
            "open-link"
          ]
        },
        "titleSource": {
          "type": "string",
          "enum": [
            "input",
            "issue-derived",
            "none"
          ]
        },
        "bodySource": {
          "type": "string",
          "enum": [
            "draft-output",
            "none"
          ]
        },
        "labelSource": {
          "type": "string",
          "enum": [
            "issue-template",
            "none"
          ]
        },
        "baseSource": {
          "type": "string",
          "enum": [
            "input-or-default",
            "none"
          ]
        },
        "branchSource": {
          "type": "string",
          "enum": [
            "current-or-input",
            "derived-or-current",
            "none"
          ]
        },
        "issueSource": {
          "type": "string",
          "enum": [
            "input-or-snapshot",
            "input",
            "none"
          ]
        },
        "pullRequestTemplate": {
          "type": "string",
          "minLength": 1
        },
        "urlSource": {
          "type": "string",
          "enum": [
            "target-url",
            "none"
          ]
        }
      }
    }
  },
  "required": [
    "schema",
    "repository",
    "issueTemplates",
    "pullRequestTemplates",
    "contactLinks",
    "routes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema": {
      "type": "string",
      "const": "github-intake/catalog@v1"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "issueTemplates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "name",
          "path",
          "titlePrefix",
          "labels",
          "summary"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^\\.github/ISSUE_TEMPLATE/.+\\.yml$"
          },
          "titlePrefix": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pullRequestTemplates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "path",
          "templateLabel",
          "metadataMode",
          "summary"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^\\.github/(?:PULL_REQUEST_TEMPLATE/.+\\.md|pull_request_template\\.md)$"
          },
          "templateLabel": {
            "type": "string",
            "minLength": 1
          },
          "metadataMode": {
            "type": "string",
            "enum": [
              "agent",
              "human"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "contactLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "url",
          "about"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "about": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario",
          "routeType",
          "targetKey",
          "helperPath",
          "command",
          "execution",
          "summary"
        ],
        "properties": {
          "scenario": {
            "type": "string",
            "minLength": 1
          },
          "routeType": {
            "type": "string",
            "enum": [
              "issue-template",
              "pull-request-template",
              "contact-link"
            ]
          },
          "targetKey": {
            "type": "string",
            "minLength": 1
          },
          "helperPath": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "executeCommand": {
            "type": "string",
            "minLength": 1
          },
          "execution": {
            "$ref": "#/$defs/execution"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
