{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/downstream-repo-graph-policy-v1.schema.json",
  "title": "Downstream Repo Graph Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "compareRepository",
    "repositories"
  ],
  "properties": {
    "schema": {
      "const": "priority/downstream-repo-graph-policy@v1"
    },
    "compareRepository": {
      "type": "string",
      "minLength": 1
    },
    "repositories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repository"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "kind",
        "roles"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "supervisor",
            "canonical-template",
            "consumer-fork",
            "certified-consumer"
          ]
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role"
          },
          "minItems": 1
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "branch",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "producer-lineage",
            "consumer-proving-source",
            "canonical-development",
            "consumer-proving-rail",
            "upstream-producer-lineage",
            "canonical-development-mirror",
            "certified-stable-baseline"
          ]
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "localRefAlias": {
          "type": [
            "string",
            "null"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "tracksRoleId": {
          "type": [
            "string",
            "null"
          ]
        },
        "syncPolicy": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "fast-forward-only",
            null
          ]
        }
      }
    }
  }
}
