{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labview-community-ci-cd.github.io/schemas/downstream-onboarding-report-v1.schema.json",
  "title": "Downstream Onboarding Report v1",
  "type": "object",
  "required": [
    "schema",
    "generatedAt",
    "upstreamRepository",
    "actionRepository",
    "downstreamRepository",
    "targetBranch",
    "branchResolution",
    "repository",
    "checklist",
    "metrics",
    "summary",
    "hardeningBacklog"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "priority/downstream-onboarding-report@v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "upstreamRepository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "actionRepository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "downstreamRepository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "targetBranch": {
      "type": "string",
      "minLength": 1
    },
    "branchResolution": {
      "type": "object",
      "required": [
        "requestedBranchOverride",
        "repositoryDefaultBranch",
        "evaluatedBranch",
        "source"
      ],
      "properties": {
        "requestedBranchOverride": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "repositoryDefaultBranch": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evaluatedBranch": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": [
            "explicit-override",
            "live-repository-default-branch",
            "fallback-default-branch"
          ]
        }
      },
      "additionalProperties": false
    },
    "pilot": {
      "type": "object",
      "properties": {
        "startedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "parentIssue": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "defaultBranch": {
          "type": [
            "string",
            "null"
          ]
        },
        "evaluatedBranch": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchResolutionSource": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "explicit-override",
            "live-repository-default-branch",
            "fallback-default-branch",
            null
          ]
        },
        "htmlUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "private": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "required",
          "severity",
          "status",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P1",
              "P2",
              "P3"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "reason": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          },
          "evidence": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "requiredFailures",
        "warningCount",
        "frictionScore"
      ],
      "properties": {
        "startedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "firstSuccessfulConsumptionAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "onboardingLeadTimeHours": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "runAttemptsUntilGreen": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "requiredFailures": {
          "type": "integer",
          "minimum": 0
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0
        },
        "frictionScore": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "totalChecklist",
        "passCount",
        "warnCount",
        "failCount",
        "requiredFailCount"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail"
          ]
        },
        "totalChecklist": {
          "type": "integer",
          "minimum": 0
        },
        "passCount": {
          "type": "integer",
          "minimum": 0
        },
        "warnCount": {
          "type": "integer",
          "minimum": 0
        },
        "failCount": {
          "type": "integer",
          "minimum": 0
        },
        "requiredFailCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "hardeningBacklog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "title",
          "severity",
          "status",
          "reason",
          "recommendation"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P1",
              "P2",
              "P3"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "warn",
              "fail"
            ]
          },
          "reason": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "hardeningIssues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
