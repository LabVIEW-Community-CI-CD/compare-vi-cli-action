{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/delivery-agent-policy-v1.schema.json",
  "title": "Delivery Agent Policy v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "backlogAuthority",
    "implementationRemote",
    "autoSlice",
    "autoMerge",
    "maxActiveCodingLanes",
    "allowPolicyMutations",
    "allowReleaseAdmin",
    "stopWhenNoOpenEpics"
  ],
  "properties": {
    "schema": { "const": "priority/delivery-agent-policy@v1" },
    "backlogAuthority": { "const": "issues" },
    "implementationRemote": { "enum": ["origin", "personal", "upstream"] },
    "autoSlice": { "type": "boolean" },
    "autoMerge": { "type": "boolean" },
    "maxActiveCodingLanes": { "type": "integer", "minimum": 1 },
    "allowPolicyMutations": { "type": "boolean" },
    "allowReleaseAdmin": { "type": "boolean" },
    "stopWhenNoOpenEpics": { "type": "boolean" },
    "hostIsolation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": { "enum": ["hard-cutover", "phased-fallback", "guard-only"] },
        "wslDistro": { "type": "string" },
        "runnerServicePolicy": { "enum": ["stop-all-actions-runner-services", "detect-only", "best-effort"] },
        "restoreRunnerServicesOnExit": { "type": "boolean" },
        "pauseOnFingerprintDrift": { "type": "boolean" }
      }
    },
    "dockerRuntime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider": { "enum": ["native-wsl", "desktop"] },
        "dockerHost": { "type": "string" },
        "expectedOsType": { "enum": ["linux", "windows"] },
        "expectedContext": { "type": "string" },
        "manageDockerEngine": { "type": "boolean" },
        "allowHostEngineMutation": { "type": "boolean" }
      }
    },
    "localReviewLoop": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "bodyMarkers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "receiptPath": { "type": "string" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "markdownlint": { "type": "boolean" },
        "requirementsVerification": { "type": "boolean" },
        "niLinuxReviewSuite": { "type": "boolean" },
        "singleViHistory": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "targetPath": { "type": "string" },
            "branchRef": { "type": "string" },
            "baselineRef": { "type": "string" },
            "maxCommitCount": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "turnBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "maxMinutes": { "type": "integer", "minimum": 1 },
        "maxToolCalls": { "type": "integer", "minimum": 1 }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "blockerBackoffMinutes": { "type": "integer", "minimum": 0 },
        "rateLimitCooldownMinutes": { "type": "integer", "minimum": 0 }
      }
    },
    "codingTurnCommand": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
