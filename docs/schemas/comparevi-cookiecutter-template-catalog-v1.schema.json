{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/comparevi-cookiecutter-template-catalog-v1.schema.json",
  "title": "CompareVI Cookiecutter Template Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "templateRoot",
    "cookiecutterVersion",
    "runtimeCacheRoot",
    "scaffoldResultsRoot",
    "templates"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference for editor/tooling discovery."
    },
    "schema": {
      "const": "comparevi-cookiecutter-template-catalog@v1"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "templateRoot": {
      "type": "string",
      "minLength": 1
    },
    "cookiecutterVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "runtimeCacheRoot": {
      "type": "string",
      "minLength": 1
    },
    "scaffoldResultsRoot": {
      "type": "string",
      "minLength": 1
    },
    "templates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "directory",
          "projectSlugKey",
          "defaultOutputRoot",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "directory": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._/-]+$"
          },
          "projectSlugKey": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "defaultOutputRoot": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
