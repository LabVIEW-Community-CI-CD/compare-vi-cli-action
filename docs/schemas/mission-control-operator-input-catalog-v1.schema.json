{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/mission-control-operator-input-catalog-v1.schema.json",
  "title": "Mission Control Operator Input Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "intents", "focuses", "overrides"],
  "properties": {
    "schema": {
      "const": "priority/mission-control-operator-input-catalog@v1"
    },
    "intents": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/intent"
      }
    },
    "focuses": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/focus"
      }
    },
    "overrides": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/override"
      }
    }
  },
  "$defs": {
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "allowedFocuses", "description"],
      "properties": {
        "id": {
          "enum": [
            "continue-driving-autonomously",
            "finish-live-standing-lane",
            "stabilize-current-head-failure",
            "restore-intake",
            "prepare-parked-lane"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "allowedFocuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "standing-priority",
              "current-head-failure",
              "queue-health",
              "handoff",
              "policy-drift",
              "docs-contract"
            ]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      }
    },
    "focus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "standingPriorityRequired", "description"],
      "properties": {
        "id": {
          "enum": [
            "standing-priority",
            "current-head-failure",
            "queue-health",
            "handoff",
            "policy-drift",
            "docs-contract"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "standingPriorityRequired": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      }
    },
    "override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "valueType", "wideningAllowed", "description"],
      "properties": {
        "key": {
          "enum": [
            "allowAdminMerge",
            "allowForkBaseDispatch",
            "allowParkedLane",
            "copilotCliUsage",
            "requireProjectBoardApply"
          ]
        },
        "valueType": {
          "enum": ["boolean", "enum"]
        },
        "allowedValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "wideningAllowed": {
          "const": false
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "key": {
                "enum": [
                  "allowAdminMerge",
                  "allowForkBaseDispatch",
                  "allowParkedLane",
                  "requireProjectBoardApply"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "valueType": {
                "const": "boolean"
              },
              "allowedValues": false
            }
          }
        },
        {
          "if": {
            "properties": {
              "key": {
                "const": "copilotCliUsage"
              }
            }
          },
          "then": {
            "required": ["allowedValues"],
            "properties": {
              "valueType": {
                "const": "enum"
              },
              "allowedValues": {
                "const": ["optional", "required"]
              }
            }
          }
        }
      ]
    }
  }
}
