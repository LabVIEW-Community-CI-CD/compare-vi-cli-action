{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/release-vi-history-policy-v1.schema.json",
  "title": "Release VI History Policy Gate",
  "type": "object",
  "required": [
    "schema",
    "requiredOs",
    "allowedGateOutcomes",
    "allowedResultClasses",
    "defaultProfilePolicy",
    "profilePolicies"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "release-vi-history/policy@v1"
    },
    "requiredOs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "linux",
          "windows"
        ]
      }
    },
    "allowedGateOutcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "allowedResultClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "defaultProfilePolicy": {
      "type": "object",
      "required": [
        "mode",
        "requiredScenarios"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "strict",
            "warn"
          ]
        },
        "requiredScenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "profilePolicies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile",
          "mode",
          "requiredScenarios"
        ],
        "properties": {
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "strict",
              "warn"
            ]
          },
          "requiredScenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
