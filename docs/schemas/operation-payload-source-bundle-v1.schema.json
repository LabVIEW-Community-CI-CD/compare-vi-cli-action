{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/operation-payload-source-bundle-v1.schema.json",
  "title": "Operation payload source bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "payloadMode",
    "sourceRepositorySlug",
    "sourceRepositoryUrl",
    "sourceLicenseSpdx",
    "ownership",
    "implementationBasis",
    "intendedCertificationSurface",
    "intendedChangeKinds",
    "expectedOperationFiles",
    "checkedInOperationFiles",
    "executableState",
    "currentState",
    "promotionTarget",
    "promotionBlocked",
    "blockingReasons",
    "notes"
  ],
  "properties": {
    "schema": {
      "const": "comparevi/operation-payload-source-bundle@v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "payloadMode": {
      "type": "string",
      "enum": [
        "additional-operation-directory",
        "builtin"
      ]
    },
    "sourceRepositorySlug": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "sourceRepositoryUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/?$"
    },
    "sourceLicenseSpdx": {
      "type": "string",
      "minLength": 1
    },
    "ownership": {
      "type": "string",
      "enum": [
        "repo-owned"
      ]
    },
    "implementationBasis": {
      "type": "string",
      "minLength": 1
    },
    "intendedCertificationSurface": {
      "type": "string",
      "minLength": 1
    },
    "intendedChangeKinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "added",
          "deleted",
          "modified"
        ]
      }
    },
    "expectedOperationFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkedInOperationFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "executableState": {
      "type": "string",
      "enum": [
        "source-only",
        "runnable"
      ]
    },
    "currentState": {
      "type": "string",
      "minLength": 1
    },
    "promotionTarget": {
      "type": "string",
      "minLength": 1
    },
    "promotionBlocked": {
      "type": "boolean"
    },
    "blockingReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authoringBootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue",
        "sourceKind",
        "preferredInstalledOperation"
      ],
      "properties": {
        "issue": {
          "type": "integer",
          "minimum": 1
        },
        "sourceKind": {
          "type": "string",
          "enum": [
            "installed-cli-operation",
            "ni-example"
          ]
        },
        "preferredInstalledOperation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
