{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Release Review Scenario Summary",
  "type": "object",
  "required": [
    "schema",
    "generatedAtUtc",
    "tag",
    "os",
    "scenarioSet",
    "overall",
    "scenarios"
  ],
  "properties": {
    "schema": {
      "const": "release-review-scenario-summary-v1"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "tag": {
      "type": "string"
    },
    "os": {
      "type": "string",
      "enum": [
        "windows-latest",
        "ubuntu-latest",
        "macos-latest"
      ]
    },
    "scenarioSet": {
      "type": "string"
    },
    "overall": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "mixed",
        "skipped"
      ]
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "sourceOutcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "checksum",
              "smoke-cli"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skipped"
            ]
          },
          "sourceOutcome": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "cancelled",
              "skipped",
              "none"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
