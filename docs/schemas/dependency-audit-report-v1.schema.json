{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dependency Audit Report v1",
  "type": "object",
  "required": [
    "schema",
    "schemaVersion",
    "generatedAt",
    "mode",
    "result",
    "command",
    "execution",
    "packageState",
    "thresholds",
    "summary",
    "packages",
    "breaches",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "priority/dependency-audit@v1"
    },
    "schemaVersion": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "observe",
        "enforce"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail",
        "error"
      ]
    },
    "command": {
      "type": "object",
      "required": [
        "command",
        "args",
        "sanitizedNpmEnv",
        "rawOutputPath"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sanitizedNpmEnv": {
          "type": "boolean"
        },
        "rawOutputPath": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "npmExitCode",
        "stderr",
        "jsonParsed"
      ],
      "properties": {
        "npmExitCode": {
          "type": "integer"
        },
        "stderr": {
          "type": [
            "string",
            "null"
          ]
        },
        "jsonParsed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "packageState": {
      "type": "object",
      "required": [
        "nodeVersion",
        "packageJson",
        "packageLock",
        "fingerprintSha256"
      ],
      "properties": {
        "nodeVersion": {
          "type": "string"
        },
        "packageJson": {
          "type": "object",
          "required": [
            "path",
            "exists",
            "sha256",
            "packageName",
            "packageVersion"
          ],
          "properties": {
            "path": {
              "type": "string"
            },
            "exists": {
              "type": "boolean"
            },
            "sha256": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-f]{64}$"
            },
            "packageName": {
              "type": [
                "string",
                "null"
              ]
            },
            "packageVersion": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "packageLock": {
          "type": "object",
          "required": [
            "path",
            "exists",
            "sha256",
            "lockfileVersion"
          ],
          "properties": {
            "path": {
              "type": "string"
            },
            "exists": {
              "type": "boolean"
            },
            "sha256": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-f]{64}$"
            },
            "lockfileVersion": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "fingerprintSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "thresholds": {
      "type": "object",
      "required": [
        "total",
        "critical",
        "high",
        "moderate"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "moderate": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "critical",
        "high",
        "moderate",
        "low",
        "info",
        "dependencyCounts"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "moderate": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        },
        "dependencyCounts": {
          "type": "object",
          "required": [
            "prod",
            "dev",
            "optional",
            "peer",
            "peerOptional",
            "total"
          ],
          "properties": {
            "prod": {
              "type": "integer",
              "minimum": 0
            },
            "dev": {
              "type": "integer",
              "minimum": 0
            },
            "optional": {
              "type": "integer",
              "minimum": 0
            },
            "peer": {
              "type": "integer",
              "minimum": 0
            },
            "peerOptional": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "severity",
          "direct",
          "range",
          "fixAvailable",
          "fixTarget",
          "fixSemVerMajor",
          "viaCount",
          "via",
          "nodeCount"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "direct": {
            "type": "boolean"
          },
          "range": {
            "type": [
              "string",
              "null"
            ]
          },
          "fixAvailable": {
            "type": "boolean"
          },
          "fixTarget": {
            "type": [
              "string",
              "null"
            ]
          },
          "fixSemVerMajor": {
            "type": "boolean"
          },
          "viaCount": {
            "type": "integer",
            "minimum": 0
          },
          "via": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "severity"
              ],
              "properties": {
                "source": {
                  "type": "string"
                },
                "severity": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "nodeCount": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "breaches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "count",
          "threshold"
        ],
        "properties": {
          "key": {
            "type": "string",
            "enum": [
              "total",
              "critical",
              "high",
              "moderate"
            ]
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "threshold": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
