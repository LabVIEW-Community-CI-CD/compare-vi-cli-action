{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comparevi.dev/throughput-scorecard-v1.schema.json",
  "title": "Throughput Scorecard v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "generatedAt", "inputs", "workerPool", "logicalLaneAllocation", "queue", "mergeQueueUtilization", "concurrentLanes", "delivery", "summary"],
  "properties": {
    "schema": {
      "const": "priority/throughput-scorecard@v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": ["string", "null"]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeStatePath", "deliveryMemoryPath", "queueReportPath", "concurrentLaneStatusPath", "hostRamBudgetPath", "utilizationPolicyPath"],
      "properties": {
        "runtimeStatePath": { "type": ["string", "null"] },
        "deliveryMemoryPath": { "type": ["string", "null"] },
        "queueReportPath": { "type": ["string", "null"] },
        "concurrentLaneStatusPath": { "type": ["string", "null"] },
        "hostRamBudgetPath": { "type": ["string", "null"] },
        "utilizationPolicyPath": { "type": ["string", "null"] }
      }
    },
    "workerPool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetSlotCount",
        "occupiedSlotCount",
        "availableSlotCount",
        "releasedLaneCount",
        "utilizationRatio",
        "activeCodingLanes",
        "liveOrchestratorLane"
      ],
      "properties": {
        "targetSlotCount": { "type": "integer", "minimum": 0 },
        "occupiedSlotCount": { "type": "integer", "minimum": 0 },
        "availableSlotCount": { "type": "integer", "minimum": 0 },
        "releasedLaneCount": { "type": "integer", "minimum": 0 },
        "utilizationRatio": { "type": "number", "minimum": 0 },
        "activeCodingLanes": { "type": "integer", "minimum": 0 },
        "liveOrchestratorLane": { "type": "string" }
      }
    },
    "logicalLaneAllocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capacityMode",
        "maxLogicalLaneCount",
        "effectiveLogicalLaneCount",
        "reservedLaneCount",
        "implementationLaneBudget",
        "allocatedLogicalLaneCount",
        "allocationRatio",
        "allocationFloorRatio",
        "floorSatisfied",
        "hostRamProfile",
        "hostRamRecommendedParallelism",
        "capacitySource"
      ],
      "properties": {
        "capacityMode": { "enum": ["fixed-target", "host-ram-adaptive"] },
        "maxLogicalLaneCount": { "type": "integer", "minimum": 0 },
        "effectiveLogicalLaneCount": { "type": "integer", "minimum": 0 },
        "reservedLaneCount": { "type": "integer", "minimum": 0 },
        "implementationLaneBudget": { "type": "integer", "minimum": 0 },
        "allocatedLogicalLaneCount": { "type": "integer", "minimum": 0 },
        "allocationRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "allocationFloorRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "floorSatisfied": { "type": "boolean" },
        "hostRamProfile": { "type": ["string", "null"] },
        "hostRamRecommendedParallelism": { "type": ["integer", "null"], "minimum": 1 },
        "capacitySource": { "enum": ["policy-ceiling", "host-ram-budget"] }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readyPrInventory",
        "inflight",
        "capacity",
        "effectiveMaxInflight",
        "paused",
        "throughputMode",
        "governorMode",
        "readySetTop"
      ],
      "properties": {
        "readyPrInventory": { "type": "integer", "minimum": 0 },
        "inflight": { "type": "integer", "minimum": 0 },
        "capacity": { "type": "integer", "minimum": 0 },
        "effectiveMaxInflight": { "type": "integer", "minimum": 0 },
        "paused": { "type": "boolean" },
        "throughputMode": { "type": ["string", "null"] },
        "governorMode": { "type": ["string", "null"] },
        "readySetTop": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "mergeQueueUtilization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "observed", "status", "reasons"],
      "properties": {
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyInventoryFloor", "occupancyFloorRatio", "occupancyTargetRatio", "treatPausedQueueAsExempt"],
          "properties": {
            "readyInventoryFloor": { "type": "integer", "minimum": 0 },
            "occupancyFloorRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "occupancyTargetRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "treatPausedQueueAsExempt": { "type": "boolean" }
          }
        },
        "observed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyPrInventory", "inflight", "effectiveMaxInflight", "occupancyRatio", "paused"],
          "properties": {
            "readyPrInventory": { "type": "integer", "minimum": 0 },
            "inflight": { "type": "integer", "minimum": 0 },
            "effectiveMaxInflight": { "type": "integer", "minimum": 0 },
            "occupancyRatio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "paused": { "type": "boolean" }
          }
        },
        "status": { "enum": ["pass", "warn"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "concurrentLanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "exists",
        "error",
        "status",
        "hostedObservationStatus",
        "pullRequestObservationStatus",
        "orchestratorDisposition",
        "workerDisposition",
        "selectedBundleId",
        "laneCount",
        "activeLaneCount",
        "completedLaneCount",
        "failedLaneCount",
        "blockedLaneCount",
        "plannedLaneCount",
        "deferredLaneCount",
        "manualLaneCount",
        "shadowLaneCount",
        "idleClassificationCoverage"
      ],
      "properties": {
        "path": { "type": ["string", "null"] },
        "exists": { "type": "boolean" },
        "error": { "type": ["string", "null"] },
        "status": { "type": "string", "minLength": 1 },
        "hostedObservationStatus": { "type": ["string", "null"] },
        "pullRequestObservationStatus": { "type": ["string", "null"] },
        "orchestratorDisposition": { "type": ["string", "null"] },
        "workerDisposition": {
          "enum": ["release", "retain", "investigate", "unknown"]
        },
        "selectedBundleId": { "type": ["string", "null"] },
        "laneCount": { "type": "integer", "minimum": 0 },
        "activeLaneCount": { "type": "integer", "minimum": 0 },
        "completedLaneCount": { "type": "integer", "minimum": 0 },
        "failedLaneCount": { "type": "integer", "minimum": 0 },
        "blockedLaneCount": { "type": "integer", "minimum": 0 },
        "plannedLaneCount": { "type": "integer", "minimum": 0 },
        "deferredLaneCount": { "type": "integer", "minimum": 0 },
        "manualLaneCount": { "type": "integer", "minimum": 0 },
        "shadowLaneCount": { "type": "integer", "minimum": 0 },
        "idleClassificationCoverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "managedLaneCount",
            "nonWorkingLaneCount",
            "classifiedLaneCount",
            "unclassifiedLaneCount",
            "coverageRatio",
            "stateCounts"
          ],
          "properties": {
            "managedLaneCount": { "type": "integer", "minimum": 0 },
            "nonWorkingLaneCount": { "type": "integer", "minimum": 0 },
            "classifiedLaneCount": { "type": "integer", "minimum": 0 },
            "unclassifiedLaneCount": { "type": "integer", "minimum": 0 },
            "coverageRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "stateCounts": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "waiting-hosted",
                "waiting-merge",
                "policy-paused",
                "blocked",
                "prewarm",
                "operator-steering",
                "queue-empty"
              ],
              "properties": {
                "waiting-hosted": { "type": "integer", "minimum": 0 },
                "waiting-merge": { "type": "integer", "minimum": 0 },
                "policy-paused": { "type": "integer", "minimum": 0 },
                "blocked": { "type": "integer", "minimum": 0 },
                "prewarm": { "type": "integer", "minimum": 0 },
                "operator-steering": { "type": "integer", "minimum": 0 },
                "queue-empty": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalTerminalPullRequestCount",
        "mergedPullRequestCount",
        "closedPullRequestCount",
        "hostedWaitEscapeCount",
        "meanTerminalDurationMinutes",
        "viHistorySuitePullRequestCount"
      ],
      "properties": {
        "totalTerminalPullRequestCount": { "type": "integer", "minimum": 0 },
        "mergedPullRequestCount": { "type": "integer", "minimum": 0 },
        "closedPullRequestCount": { "type": "integer", "minimum": 0 },
        "hostedWaitEscapeCount": { "type": "integer", "minimum": 0 },
        "meanTerminalDurationMinutes": { "type": ["number", "null"], "minimum": 0 },
        "viHistorySuitePullRequestCount": { "type": "integer", "minimum": 0 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons", "metrics"],
      "properties": {
        "status": { "enum": ["pass", "warn"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currentWorkerUtilizationRatio",
            "readyPrInventory",
            "mergeQueueInflight",
            "mergeQueueCapacity",
            "mergeQueueOccupancyRatio",
            "mergeQueueReadyInventoryFloor",
            "logicalLaneAllocationRatio",
            "logicalLaneAllocationFloorRatio",
            "effectiveLogicalLaneCount",
            "concurrentLaneActiveCount",
            "concurrentLaneDeferredCount",
            "idleClassificationManagedLaneCount",
            "idleClassificationNonWorkingLaneCount",
            "idleClassificationClassifiedLaneCount",
            "idleClassificationCoverageRatio",
            "hostedWaitEscapeCount",
            "meanTerminalDurationMinutes"
          ],
          "properties": {
            "currentWorkerUtilizationRatio": { "type": "number", "minimum": 0 },
            "readyPrInventory": { "type": "integer", "minimum": 0 },
            "mergeQueueInflight": { "type": "integer", "minimum": 0 },
            "mergeQueueCapacity": { "type": "integer", "minimum": 0 },
            "mergeQueueOccupancyRatio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "mergeQueueReadyInventoryFloor": { "type": "integer", "minimum": 0 },
            "logicalLaneAllocationRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "logicalLaneAllocationFloorRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "effectiveLogicalLaneCount": { "type": "integer", "minimum": 0 },
            "concurrentLaneActiveCount": { "type": "integer", "minimum": 0 },
            "concurrentLaneDeferredCount": { "type": "integer", "minimum": 0 },
            "idleClassificationManagedLaneCount": { "type": "integer", "minimum": 0 },
            "idleClassificationNonWorkingLaneCount": { "type": "integer", "minimum": 0 },
            "idleClassificationClassifiedLaneCount": { "type": "integer", "minimum": 0 },
            "idleClassificationCoverageRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "hostedWaitEscapeCount": { "type": "integer", "minimum": 0 },
            "meanTerminalDurationMinutes": { "type": ["number", "null"], "minimum": 0 }
          }
        }
      }
    }
  }
}
