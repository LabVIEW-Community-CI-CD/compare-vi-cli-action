{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.comparevi.dev/throughput-scorecard-v1.schema.json",
  "title": "Throughput Scorecard v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "generatedAt", "inputs", "workerPool", "queue", "mergeQueueUtilization", "concurrentLanes", "delivery", "summary"],
  "properties": {
    "schema": {
      "const": "priority/throughput-scorecard@v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": ["string", "null"]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeStatePath", "deliveryMemoryPath", "queueReportPath", "concurrentLaneStatusPath", "utilizationPolicyPath"],
      "properties": {
        "runtimeStatePath": { "type": ["string", "null"] },
        "deliveryMemoryPath": { "type": ["string", "null"] },
        "queueReportPath": { "type": ["string", "null"] },
        "concurrentLaneStatusPath": { "type": ["string", "null"] },
        "utilizationPolicyPath": { "type": ["string", "null"] }
      }
    },
    "workerPool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetSlotCount",
        "occupiedSlotCount",
        "availableSlotCount",
        "releasedLaneCount",
        "utilizationRatio",
        "activeCodingLanes"
      ],
      "properties": {
        "targetSlotCount": { "type": "integer", "minimum": 0 },
        "occupiedSlotCount": { "type": "integer", "minimum": 0 },
        "availableSlotCount": { "type": "integer", "minimum": 0 },
        "releasedLaneCount": { "type": "integer", "minimum": 0 },
        "utilizationRatio": { "type": "number", "minimum": 0 },
        "activeCodingLanes": { "type": "integer", "minimum": 0 }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readyPrInventory",
        "inflight",
        "capacity",
        "effectiveMaxInflight",
        "paused",
        "throughputMode",
        "governorMode",
        "readySetTop"
      ],
      "properties": {
        "readyPrInventory": { "type": "integer", "minimum": 0 },
        "inflight": { "type": "integer", "minimum": 0 },
        "capacity": { "type": "integer", "minimum": 0 },
        "effectiveMaxInflight": { "type": "integer", "minimum": 0 },
        "paused": { "type": "boolean" },
        "throughputMode": { "type": ["string", "null"] },
        "governorMode": { "type": ["string", "null"] },
        "readySetTop": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "mergeQueueUtilization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "observed", "status", "reasons"],
      "properties": {
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyInventoryFloor", "occupancyFloorRatio", "occupancyTargetRatio", "treatPausedQueueAsExempt"],
          "properties": {
            "readyInventoryFloor": { "type": "integer", "minimum": 0 },
            "occupancyFloorRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "occupancyTargetRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "treatPausedQueueAsExempt": { "type": "boolean" }
          }
        },
        "observed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readyPrInventory", "inflight", "effectiveMaxInflight", "occupancyRatio", "paused"],
          "properties": {
            "readyPrInventory": { "type": "integer", "minimum": 0 },
            "inflight": { "type": "integer", "minimum": 0 },
            "effectiveMaxInflight": { "type": "integer", "minimum": 0 },
            "occupancyRatio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "paused": { "type": "boolean" }
          }
        },
        "status": { "enum": ["pass", "warn"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "concurrentLanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "exists",
        "error",
        "status",
        "hostedObservationStatus",
        "pullRequestObservationStatus",
        "orchestratorDisposition",
        "workerDisposition",
        "selectedBundleId",
        "laneCount",
        "activeLaneCount",
        "completedLaneCount",
        "failedLaneCount",
        "blockedLaneCount",
        "plannedLaneCount",
        "deferredLaneCount",
        "manualLaneCount",
        "shadowLaneCount"
      ],
      "properties": {
        "path": { "type": ["string", "null"] },
        "exists": { "type": "boolean" },
        "error": { "type": ["string", "null"] },
        "status": { "type": "string", "minLength": 1 },
        "hostedObservationStatus": { "type": ["string", "null"] },
        "pullRequestObservationStatus": { "type": ["string", "null"] },
        "orchestratorDisposition": { "type": ["string", "null"] },
        "workerDisposition": {
          "enum": ["release", "retain", "investigate", "unknown"]
        },
        "selectedBundleId": { "type": ["string", "null"] },
        "laneCount": { "type": "integer", "minimum": 0 },
        "activeLaneCount": { "type": "integer", "minimum": 0 },
        "completedLaneCount": { "type": "integer", "minimum": 0 },
        "failedLaneCount": { "type": "integer", "minimum": 0 },
        "blockedLaneCount": { "type": "integer", "minimum": 0 },
        "plannedLaneCount": { "type": "integer", "minimum": 0 },
        "deferredLaneCount": { "type": "integer", "minimum": 0 },
        "manualLaneCount": { "type": "integer", "minimum": 0 },
        "shadowLaneCount": { "type": "integer", "minimum": 0 }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalTerminalPullRequestCount",
        "mergedPullRequestCount",
        "closedPullRequestCount",
        "hostedWaitEscapeCount",
        "meanTerminalDurationMinutes",
        "viHistorySuitePullRequestCount"
      ],
      "properties": {
        "totalTerminalPullRequestCount": { "type": "integer", "minimum": 0 },
        "mergedPullRequestCount": { "type": "integer", "minimum": 0 },
        "closedPullRequestCount": { "type": "integer", "minimum": 0 },
        "hostedWaitEscapeCount": { "type": "integer", "minimum": 0 },
        "meanTerminalDurationMinutes": { "type": ["number", "null"], "minimum": 0 },
        "viHistorySuitePullRequestCount": { "type": "integer", "minimum": 0 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasons", "metrics"],
      "properties": {
        "status": { "enum": ["pass", "warn"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "currentWorkerUtilizationRatio",
            "readyPrInventory",
            "mergeQueueInflight",
            "mergeQueueCapacity",
            "mergeQueueOccupancyRatio",
            "mergeQueueReadyInventoryFloor",
            "concurrentLaneActiveCount",
            "concurrentLaneDeferredCount",
            "hostedWaitEscapeCount",
            "meanTerminalDurationMinutes"
          ],
          "properties": {
            "currentWorkerUtilizationRatio": { "type": "number", "minimum": 0 },
            "readyPrInventory": { "type": "integer", "minimum": 0 },
            "mergeQueueInflight": { "type": "integer", "minimum": 0 },
            "mergeQueueCapacity": { "type": "integer", "minimum": 0 },
            "mergeQueueOccupancyRatio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "mergeQueueReadyInventoryFloor": { "type": "integer", "minimum": 0 },
            "concurrentLaneActiveCount": { "type": "integer", "minimum": 0 },
            "concurrentLaneDeferredCount": { "type": "integer", "minimum": 0 },
            "hostedWaitEscapeCount": { "type": "integer", "minimum": 0 },
            "meanTerminalDurationMinutes": { "type": ["number", "null"], "minimum": 0 }
          }
        }
      }
    }
  }
}
