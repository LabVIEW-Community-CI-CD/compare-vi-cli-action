{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/delivery-agent-runtime-state-v1.schema.json",
  "title": "Delivery Agent Runtime State v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "generatedAt",
    "repository",
    "runtimeDir",
    "status",
    "laneLifecycle",
    "activeCodingLanes",
    "activeLane"
  ],
  "properties": {
    "schema": { "const": "priority/delivery-agent-runtime-state@v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repository": { "type": "string" },
    "runtimeDir": { "type": "string" },
    "status": { "enum": ["running", "blocked", "idle"] },
    "laneLifecycle": {
      "enum": [
        "planning",
        "reshaping-backlog",
        "coding",
        "waiting-ci",
        "waiting-review",
        "ready-merge",
        "blocked",
        "complete",
        "idle"
      ]
    },
    "activeCodingLanes": { "type": "integer", "minimum": 0 },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "implementationRemote", "maxActiveCodingLanes"],
      "properties": {
        "schema": { "const": "priority/delivery-agent-policy@v1" },
        "implementationRemote": { "type": "string" },
        "maxActiveCodingLanes": { "type": "integer", "minimum": 1 }
      }
    },
    "activeLane": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "laneId", "laneLifecycle", "blockerClass"],
      "properties": {
        "schema": { "const": "priority/delivery-agent-lane-state@v1" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "laneId": { "type": "string" },
        "issue": { "type": ["integer", "null"], "minimum": 1 },
        "epic": { "type": ["integer", "null"], "minimum": 1 },
        "branch": { "type": ["string", "null"] },
        "forkRemote": { "type": ["string", "null"] },
        "prUrl": { "type": ["string", "null"], "format": "uri-reference" },
        "blockerClass": { "type": "string" },
        "laneLifecycle": {
          "enum": [
            "planning",
            "reshaping-backlog",
            "coding",
            "waiting-ci",
            "waiting-review",
            "ready-merge",
            "blocked",
            "complete",
            "idle"
          ]
        },
        "actionType": { "type": ["string", "null"] },
        "outcome": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "retryable": { "type": "boolean" },
        "nextWakeCondition": { "type": ["string", "null"] }
      }
    },
    "artifacts": { "type": "object", "additionalProperties": true }
  }
}
