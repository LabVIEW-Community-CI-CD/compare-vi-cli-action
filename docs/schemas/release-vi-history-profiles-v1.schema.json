{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labview-community-ci-cd.github.io/compare-vi-cli-action/schemas/release-vi-history-profiles-v1.schema.json",
  "title": "Release VI History Review Profiles",
  "type": "object",
  "required": [
    "schema",
    "defaultProfile",
    "osTargets",
    "profiles"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "release-vi-history/profiles@v1"
    },
    "defaultProfile": {
      "type": "string",
      "minLength": 1
    },
    "osTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "runner",
          "image"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "linux",
              "windows"
            ]
          },
          "runner": {
            "type": "string",
            "minLength": 1
          },
          "image": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "scenarios"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "flags"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "flags": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
